DATABASE_URL=sua_connection_string_aqui

# F016 / ADR-009 — chave-mestra BYOK (32 bytes em base64). Gere com:
#   openssl rand -base64 32
# Sem ela o app não cifra/decifra as chaves do aluno.
BYOK_MASTER_KEY=

# Chaves de API do aluno: configure em /configuracao (BYOK). As vars abaixo
# NÃO são mais lidas pelas features — ficam só como referência / migração local.
# ANTHROPIC_API_KEY=
# GOOGLE_PLACES_API_KEY=
# PAGESPEED_API_KEY=
# SCREENSHOTONE_ACCESS_KEY=

# F014 — autenticação (Better Auth). Sem default: ausência → erro no boot
# e GET /api/health → 503. Gere: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Produção: BETTER_AUTH_URL=https://orion-lead-hunter.devemdobro.com
# Google OAuth — opcional. Ambos ou nenhum (sem meio-termo).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# F014 / ADR-010 — e-mail do magic link
# Local: docker compose up -d  → UI http://127.0.0.1:8025
EMAIL_PROVIDER=mailpit
EMAIL_FROM=orion-lead-hunter@localhost
MAILPIT_URL=http://127.0.0.1:8025
# Produção (Resend SMTP):
# EMAIL_PROVIDER=resend
# RESEND_SMTP_FROM_EMAIL=login@devemdobro.com
# RESEND_SMTP_HOST=smtp.resend.com
# RESEND_SMTP_PORT=465
# RESEND_SMTP_USER=resend
# RESEND_SMTP_PASS=

# Observabilidade (ADR-013) — Sentry. Sem DSN ⇒ no-op.
# NEXT_PUBLIC_SENTRY_DSN=   # browser (mesmo valor do DSN do projeto)
# SENTRY_DSN=               # server/edge (pode ser o mesmo)
# SENTRY_ENVIRONMENT=production
# Upload de source maps no CI (opcional):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
